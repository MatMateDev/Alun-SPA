rules_version = '2';

// ============================================================================
//  Reglas de seguridad de Firestore — Inversiones Alun SpA (portal interno)
//  Solo usuarios autenticados y en la whitelist pueden leer/escribir.
//  Pega estas reglas en: Firebase Console -> Firestore Database -> Reglas.
//  Mantén la lista 'autorizados' igual que ALLOWED_EMAILS en src/config/firebase.js
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function autorizado() {
      return request.auth != null
        && request.auth.token.email in [
          'felipe@inversionesalun.cl'
        ];
    }

    match /{document=**} {
      allow read, write: if autorizado();
    }
  }
}
